{
  "id": "ai.charm.apps.mermaid-diagram",
  "name": "Mermaid Diagram",
  "description": "A read-only Mermaid renderer that renders diagram source from appContent with configurable theme and options",
  "bundle": {
    "entry": {
      "html": "/src/index.html",
      "script": "/src/main.ts",
      "style": "/src/styles.scss"
    },
    "format": "esm",
    "dependencies": {
      "importMap": {
        "rxjs": "https://esm.sh/rxjs@7.8.1",
        "rxjs/operators": "https://esm.sh/rxjs@7.8.1/operators",
        "mermaid": "https://esm.sh/mermaid@11.4.1"
      }
    }
  },
  "runtime": {
    "appContent": true,
    "appState": true
  }
}
