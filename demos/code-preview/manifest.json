{
  "id": "code-preview",
  "name": "Code Preview",
  "description": "A static HTML/CSS preview assembled from document content blocks — edit the source in the editors, reload the preview to see your changes.",

  "bundle": {
    "format": "html",
    "entry": {
      "html": "/index.html",
      "style": "/style.css"
    },
    "files": {
      "/index.html": "charmiq://./README.md?selector=iframe-app[name='html-editor']/app-content[name='html:index.html']&format=plain",
      "/style.css": "charmiq://./README.md?selector=iframe-app[name='css-editor']/app-content[name='css:style.css']&format=plain"
    }
  },

  "runtime": {
    "type": "static",
    "description": "Static HTML/CSS demonstration"
  }
}
