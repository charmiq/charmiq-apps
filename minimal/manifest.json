{
  "id": "ai.charmiq.apps.minimal",
  "name": "Minimal App (ESM)",
  "description": "Minimal CharmIQ Application with ESM format",
  "bundle": {
    "entry": {
      "html": "/index.html",
      "script": "/main.tsx",
      "style": "/styles.scss"
    },
    "format": "esm",
    "dependencies": {
      "importMap": {
        "react": "https://esm.sh/react@18.2.0",
        "react-dom": "https://esm.sh/react-dom@18.2.0"
      }
    }
  },
  "runtime": {
    "appContent": {
      "message": { "type": "text", "description": "Message to display" }
    },
    "appState": { "count": 0 }
  }
}
